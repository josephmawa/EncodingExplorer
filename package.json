{
  "name": "encoding-explorer",
  "version": "0.1.4",
  "description": "Character Encoding Explorer",
  "main": "index.js",
  "scripts": {
    "build": "flatpak run org.flatpak.Builder --force-clean --user --install-deps-from=flathub --ccache --mirror-screenshots-url=https://dl.flathub.org/media/ --repo=repo builddir io.github.josephmawa.EncodingExplorer.json",
    "lint-manifest": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder manifest io.github.josephmawa.EncodingExplorer.json",
    "lint-appstream": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder appstream data/io.github.josephmawa.EncodingExplorer.metainfo.xml.in",
    "lint-builddir": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder builddir builddir",
    "lint-repo": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder repo repo",
    "lint": "npm run lint-manifest && npm run lint-appstream && npm run lint-builddir && npm run lint-repo",
    "init-build-dir": "flatpak run --command=meson --filesystem=host org.gnome.Sdk/x86_64/50 setup --wipe build-dir .",
    "gen-pot": "flatpak run --command=meson --filesystem=host org.gnome.Sdk/x86_64/50 compile -C build-dir EncodingExplorer-pot",
    "gen-po": "flatpak run --command=meson --filesystem=host org.gnome.Sdk/x86_64/50 compile -C build-dir EncodingExplorer-update-po",
    "rm-build-artifacts": "rm -rf .flatpak-builder builddir repo build-dir",
    "start": "flatpak run org.flatpak.Builder --run builddir io.github.josephmawa.EncodingExplorer.json /app/bin/io.github.josephmawa.EncodingExplorer"
  },
  "keywords": [
    "Character",
    "Encoding",
    "Unicode",
    "Binary"
  ],
  "author": "Jospeh Mawa",
  "license": "GPL-3.0-or-later",
  "type": "commonjs"
}
